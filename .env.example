SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
NEWS_ADMIN_KEY=change-this-news-admin-key
NEWS_STORAGE_KEY=talme:news
# Optional persistent production storage for Vercel/serverless deployments.
# Use Upstash/Vercel KV REST credentials so news edits/deletes survive refreshes and server restarts.
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
CAREERS_EMAIL_TO=hr@talme.in
CAREERS_EMAIL_FROM=no-reply@talme.in
CONTACT_EMAIL_TO=hr@talme.in
CONTACT_EMAIL_FROM=no-reply@talme.in
