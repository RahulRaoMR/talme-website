SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

BACKEND_PORT=3001
SITE_ADMIN_KEY=talme-admin
SITE_DATA_STORAGE_KEY=talme:website-data
NEWS_ADMIN_KEY=talme-admin
NEWS_STORAGE_KEY=talme:news

# Optional persistent production storage for Vercel/serverless deployments.
# Use Upstash/Vercel KV REST credentials so submissions and news edits survive serverless restarts.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

CAREERS_EMAIL_TO=hr@talme.in
CAREERS_EMAIL_FROM=no-reply@talme.in
CONTACT_EMAIL_TO=hr@talme.in
CONTACT_EMAIL_FROM=no-reply@talme.in
